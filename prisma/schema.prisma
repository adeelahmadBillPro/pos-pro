generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============ ENUMS ============

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  CASHIER
  VIEWER
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

enum ProofStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  JAZZCASH
  EASYPAISA
  BANK_TRANSFER
  SPLIT
  STORE_CREDIT
}

enum StockMovementType {
  SALE
  RETURN
  PURCHASE
  ADJUSTMENT
  TRANSFER
  DAMAGE
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  BUY_X_GET_Y
}

enum ReturnReason {
  DEFECTIVE
  WRONG_ITEM
  CUSTOMER_CHANGED_MIND
  DAMAGED_IN_DELIVERY
  OTHER
}

enum RefundMethod {
  ORIGINAL_PAYMENT
  CASH
  STORE_CREDIT
}

// ============ CORE MODELS ============

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String
  phone         String?
  pin           String?
  role          UserRole  @default(CASHIER)
  avatar        String?
  isActive      Boolean   @default(true)
  storeId       String?
  store         Store?    @relation(fields: [storeId], references: [id])

  createdOrders    Order[]        @relation("OrderCashier")
  processedReturns Return[]       @relation("ReturnProcessor")
  shifts           StaffShift[]
  auditLogs        AuditLog[]
  approvedPayments PaymentProof[] @relation("PaymentReviewer")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
  @@index([storeId])
}

model Store {
  id      String  @id @default(cuid())
  name    String
  slug    String  @unique
  address String?
  city    String?
  phone   String?
  email   String?
  logo    String?

  currency   String  @default("PKR")
  taxRate    Float   @default(0)
  taxName    String  @default("GST")
  taxEnabled Boolean @default(false)

  requireCustomer    Boolean @default(false)
  allowNegativeStock Boolean @default(false)
  autoApplyTax       Boolean @default(true)
  lowStockThreshold  Int     @default(10)
  receiptHeader      String?
  receiptFooter      String?
  receiptShowLogo    Boolean @default(true)

  subscriptionStatus SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?

  users         User[]
  products      Product[]
  categories    Category[]
  customers     Customer[]
  orders        Order[]
  suppliers     Supplier[]
  expenses      Expense[]
  discounts     Discount[]
  paymentProofs PaymentProof[]
  subscriptions Subscription[]
  posSessions   POSSession[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
}

model Plan {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  monthlyPrice Float
  yearlyPrice  Float
  maxStores   Int      @default(1)
  maxProducts Int      @default(100)
  maxUsers    Int      @default(3)
  maxOrders   Int      @default(-1)
  features    String[]
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  subscriptions Subscription[]
  paymentProofs PaymentProof[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id        String             @id @default(cuid())
  storeId   String
  store     Store              @relation(fields: [storeId], references: [id])
  planId    String
  plan      Plan               @relation(fields: [planId], references: [id])
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime
  endDate   DateTime
  autoRenew Boolean            @default(false)
  notes     String?

  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
}

model BankAccount {
  id           String  @id @default(cuid())
  bankName     String
  accountTitle String
  iban         String
  branchCode   String?
  isActive     Boolean @default(true)
  sortOrder    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentProof {
  id             String      @id @default(cuid())
  storeId        String
  store          Store       @relation(fields: [storeId], references: [id])
  planId         String
  plan           Plan        @relation(fields: [planId], references: [id])
  amount         Float
  durationMonths Int         @default(1)
  transactionId  String?
  screenshotUrl  String
  bankName       String
  senderName     String
  senderPhone    String?
  notes          String?
  status         ProofStatus @default(PENDING)

  rejectionReason String?
  reviewedById    String?
  reviewedBy      User?    @relation("PaymentReviewer", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?

  submittedAt DateTime @default(now())

  @@index([storeId])
  @@index([status])
}

model Invoice {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  amount         Float
  status         String       @default("PAID")
  paidAt         DateTime?
  dueDate        DateTime
  receiptUrl     String?
  notes          String?

  createdAt DateTime @default(now())
}

// ============ PRODUCT MODELS ============

model Category {
  id       String     @id @default(cuid())
  name     String
  slug     String
  image    String?
  parentId String?
  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")
  storeId  String
  store    Store      @relation(fields: [storeId], references: [id])
  products Product[]
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([slug, storeId])
  @@index([storeId])
}

model Product {
  id          String    @id @default(cuid())
  name        String
  description String?
  sku         String
  barcode     String?
  images      String[]  @default([])
  price       Float
  costPrice   Float     @default(0)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id])
  taxable     Boolean   @default(true)
  isActive    Boolean   @default(true)
  trackStock  Boolean   @default(true)
  unit        String    @default("pcs")
  minStock    Int       @default(5)

  variants   ProductVariant[]
  inventory  InventoryItem?
  orderItems OrderItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([sku, storeId])
  @@index([storeId])
  @@index([barcode])
  @@index([categoryId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  sku       String
  barcode   String?
  price     Float
  costPrice Float   @default(0)
  isActive  Boolean @default(true)

  inventory  InventoryItem?
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

// ============ INVENTORY ============

model InventoryItem {
  id        String         @id @default(cuid())
  productId String         @unique
  product   Product        @relation(fields: [productId], references: [id])
  variantId String?        @unique
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  quantity  Int            @default(0)
  reserved  Int            @default(0)

  movements StockMovement[]

  updatedAt DateTime @updatedAt
}

model StockMovement {
  id              String            @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem     @relation(fields: [inventoryItemId], references: [id])
  type            StockMovementType
  quantity        Int
  previousQty     Int
  newQty          Int
  reference       String?
  notes           String?
  createdById     String?

  createdAt DateTime @default(now())

  @@index([inventoryItemId])
}

model Supplier {
  id       String  @id @default(cuid())
  name     String
  phone    String?
  email    String?
  address  String?
  storeId  String
  store    Store   @relation(fields: [storeId], references: [id])
  notes    String?
  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([storeId])
}

// ============ CUSTOMER ============

model Customer {
  id            String    @id @default(cuid())
  name          String
  phone         String?
  email         String?
  address       String?
  city          String?
  dateOfBirth   DateTime?
  gender        String?
  notes         String?
  loyaltyPoints Int       @default(0)
  totalSpent    Float     @default(0)
  totalOrders   Int       @default(0)
  customerGroup String    @default("RETAIL")
  isActive      Boolean   @default(true)
  storeId       String
  store         Store     @relation(fields: [storeId], references: [id])

  orders              Order[]
  loyaltyTransactions LoyaltyTransaction[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([phone, storeId])
  @@index([storeId])
  @@index([phone])
}

model LoyaltyTransaction {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  points     Int
  type       String
  orderId    String?
  notes      String?

  createdAt DateTime @default(now())

  @@index([customerId])
}

// ============ ORDERS ============

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  storeId     String
  store       Store       @relation(fields: [storeId], references: [id])
  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id])
  cashierId   String
  cashier     User        @relation("OrderCashier", fields: [cashierId], references: [id])
  sessionId   String?
  session     POSSession? @relation(fields: [sessionId], references: [id])

  status        OrderStatus @default(COMPLETED)
  items         OrderItem[]
  payments      Payment[]
  subtotal      Float
  discountAmount Float      @default(0)
  discountCode  String?
  taxAmount     Float       @default(0)
  total         Float
  notes         String?
  receiptUrl    String?

  returns Return[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([customerId])
  @@index([orderNumber])
  @@index([createdAt])
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id])
  productId String
  product   Product        @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  name      String
  sku       String
  quantity  Int
  unitPrice Float
  costPrice Float   @default(0)
  discount  Float   @default(0)
  taxAmount Float   @default(0)
  total     Float
  notes     String?

  returnItems ReturnItem[]

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String
  order     Order         @relation(fields: [orderId], references: [id])
  method    PaymentMethod
  amount    Float
  change    Float         @default(0)
  reference String?
  status    String        @default("COMPLETED")
  notes     String?

  createdAt DateTime @default(now())

  @@index([orderId])
}

// ============ RETURNS ============

model Return {
  id            String       @id @default(cuid())
  returnNumber  String       @unique
  orderId       String
  order         Order        @relation(fields: [orderId], references: [id])
  processedById String
  processedBy   User         @relation("ReturnProcessor", fields: [processedById], references: [id])

  items        ReturnItem[]
  reason       ReturnReason
  notes        String?
  refundAmount Float
  refundMethod RefundMethod
  status       String       @default("COMPLETED")

  createdAt DateTime @default(now())

  @@index([orderId])
}

model ReturnItem {
  id          String    @id @default(cuid())
  returnId    String
  return      Return    @relation(fields: [returnId], references: [id])
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  quantity    Int
  refundAmount Float

  @@index([returnId])
}

// ============ DISCOUNTS ============

model Discount {
  id            String       @id @default(cuid())
  storeId       String
  store         Store        @relation(fields: [storeId], references: [id])
  name          String
  code          String?
  type          DiscountType
  value         Float
  minOrderValue Float?
  maxUses       Int?
  usedCount     Int          @default(0)
  startDate     DateTime?
  endDate       DateTime?
  isActive      Boolean      @default(true)
  appliesTo     String       @default("ALL")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([code, storeId])
  @@index([storeId])
}

// ============ STAFF ============

model StaffShift {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  clockIn     DateTime  @default(now())
  clockOut    DateTime?
  openingCash Float     @default(0)
  closingCash Float?
  totalSales  Float     @default(0)
  totalOrders Int       @default(0)
  notes       String?

  createdAt DateTime @default(now())

  @@index([userId])
}

model POSSession {
  id          String    @id @default(cuid())
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id])
  cashierId   String
  openingCash Float     @default(0)
  closingCash Float?
  status      String    @default("OPEN")
  startAt     DateTime  @default(now())
  endAt       DateTime?

  orders Order[]

  @@index([storeId])
}

// ============ EXPENSES ============

model Expense {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  category    String
  amount      Float
  description String
  date        DateTime @default(now())
  receipt     String?
  createdById String?

  createdAt DateTime @default(now())

  @@index([storeId])
}

// ============ AUDIT LOG ============

model AuditLog {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}
